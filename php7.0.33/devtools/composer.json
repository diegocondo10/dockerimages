{
  "name": "libelulasoft/devtools-php7",
  "description": "Dev tools pre-instalados en la imagen base PHP 7.0.33 (Codeception + PHPUnit) para proyectos con vendor hardcodeado",
  "require": {
    "php": "~7.0.33",
    "phpunit/phpunit": "^6.5",
    "codeception/codeception": "^4.1",
    "codeception/module-asserts": "^1.3",
    "codeception/module-yii2": "^1.1",
    "codeception/module-phpbrowser": "^1.0",
    "codeception/module-db": "^1.0"
  },
  "config": {
    "bin-dir": "vendor/bin",
    "sort-packages": true,
    "optimize-autoloader": true
  },
  "minimum-stability": "stable"
}
